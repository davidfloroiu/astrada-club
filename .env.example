# ─────────────────────────────────────────────────────────────
# Astrada × Whop — environment variables
# Copy to .env.local and fill in. Get the Whop values from your
# Whop dashboard (Developer → your app, and Settings → API keys).
# ─────────────────────────────────────────────────────────────

# Public site URL (used to build OAuth redirect + checkout return URLs)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Whop OAuth app (Developer → OAuth) ──
# Client id, looks like app_xxxxxxxx. Public.
NEXT_PUBLIC_WHOP_APP_ID=
# OAuth client secret. Server-only — never expose.
WHOP_CLIENT_SECRET=
# Must EXACTLY match a redirect URI registered on the Whop OAuth app.
NEXT_PUBLIC_WHOP_REDIRECT_URI=http://localhost:3000/api/auth/whop/callback

# ── Whop API key (Settings → API keys) ──
# Needs permissions: access check, member:email:read, chat:read, chat:message:create.
# Used for membership checks, chat embed tokens, and webhook member lookups.
WHOP_API_KEY=

# ── Whop webhook signing secret (Developer → Webhooks) ──
# Point the webhook at: {NEXT_PUBLIC_SITE_URL}/api/webhooks/whop
WHOP_WEBHOOK_SECRET=

# ── Session encryption (iron-session) ──
# Any random string, 32+ characters. Generate: openssl rand -base64 32
SESSION_SECRET=

# ── Resend (membership application emails) ──
# Transactional email API key, looks like re_xxxxxxxx. Server-only.
# Get it at resend.com. The sender domain (send.astradaclub.com) must be
# verified in Resend. Applications are delivered to contact@astradaclub.com.
RESEND_API_KEY=
